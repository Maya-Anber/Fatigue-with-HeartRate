{
  "name": "fitness-fatigue-system",
  "version": "1.0.0",
  "description": "fatigue assessment and rest optimization using PPG, EMG, and barbell velocity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/", "src/"],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "start:api": "ts-node src/api/server.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "fitness", "fatigue", "heart-rate", "ppg", "emg", "barbell",
    "velocity", "iot", "ai", "rest-optimization"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2"
  },
  "exports": {
    ".": "./dist/index.js",
    "./heart-rate": "./dist/heart-rate/index.js",
    "./emg": "./dist/emg/index.js",
    "./barbell": "./dist/barbell/index.js",
    "./aggregator": "./dist/aggregator/index.js",
    "./fatigue-engine": "./dist/fatigue-engine/index.js",
    "./api": "./dist/api/server.js"
  }
}
